### المرحلة 1 — Assessment Migration (أيام 2-3)

#### 1.1 — إنشاء Migration Script

أنشئ `backend/scripts/migrate-assessments.mjs`:

```javascript
/**
 * Migrates legacy Assessment sub-documents → PerformanceReview documents.
 * 
 * DRY RUN by default. Pass --apply to write.
 * 
 * Usage:
 *   node scripts/migrate-assessments.mjs           (dry run — safe)
 *   node scripts/migrate-assessments.mjs --apply   (execute)
 */
import mongoose from 'mongoose';
import dotenv from 'dotenv';
dotenv.config();

const APPLY = process.argv.includes('--apply');
const uri = process.env.MONGO_URI || 'mongodb://localhost:27017/hrms';

// ─── inline schemas (standalone script) ───────────────────────────────
const Assessment = mongoose.model('Assessment', new mongoose.Schema({
  employeeId: { type: mongoose.Schema.Types.ObjectId, unique: true },
  assessment: [ new mongoose.Schema({
    date: String,
    period: { year: Number, month: Number },
    rating: Number, feedback: String, reviewPeriod: String,
    evaluatorId: mongoose.Schema.Types.ObjectId,
    getThebounes: Boolean,
    daysBonus: Number, overtime: Number, deduction: Number,
    commitment: Number, attitude: Number, quality: Number, overall: Number,
    notesPrevious: String,
    bonusStatus: String,
    bonusApprovedBy: String, bonusApprovedAt: Date, bonusRejectionReason: String,
  }, { timestamps: true }) ],
}, { timestamps: true }));

const PerformanceReview = mongoose.model('PerformanceReview', new mongoose.Schema({
  employeeId: mongoose.Schema.Types.ObjectId,
  evaluatorId: mongoose.Schema.Types.ObjectId,
  date: String,
  period: { year: Number, month: Number },
  scores: Array, overall: Number,
  feedback: String, notesPrevious: String,
  goalsForNextPeriod: Array,
  getThebounes: Boolean,
  daysBonus: Number, overtime: Number, deduction: Number,
  bonusStatus: String,
  bonusApprovedBy: String, bonusApprovedAt: Date, bonusRejectionReason: String,
}, { timestamps: true }));

// ─── main ──────────────────────────────────────────────────────────────
async function run() {
  await mongoose.connect(uri);
  console.log('\n Connected:', uri);
  console.log(' Mode:', APPLY ? 'APPLY (writes ON)' : 'DRY RUN (no writes)');
  console.log('─'.repeat(60) + '\n');

  const docs = await Assessment.find({}).lean();
  let converted = 0, skipped = 0, errors = 0;

  for (const doc of docs) {
    const empId = doc.employeeId;
    for (const a of (doc.assessment || [])) {

      // Skip if already migrated (unique index guard)
      const exists = await PerformanceReview.findOne({
        employeeId: empId,
        'period.year': a.period?.year,
        'period.month': a.period?.month,
        evaluatorId: a.evaluatorId,
      }).lean();

      if (exists) { skipped++; continue; }

      // Build legacy scores from commitment/attitude/quality
      const scores = [];
      if (a.commitment) scores.push({ title: 'Commitment', score: a.commitment, weight: 1 });
      if (a.attitude)   scores.push({ title: 'Attitude',   score: a.attitude,   weight: 1 });
      if (a.quality)    scores.push({ title: 'Quality',    score: a.quality,    weight: 1 });

      const newDoc = {
        employeeId: empId,
        evaluatorId: a.evaluatorId,
        date: a.date || new Date().toISOString().slice(0, 10),
        period: a.period || { year: 2024, month: 1 },
        scores,
        overall: a.overall || a.rating || 0,
        feedback: a.feedback || '',
        notesPrevious: a.notesPrevious || '',
        goalsForNextPeriod: [],
        getThebounes: a.getThebounes || false,
        daysBonus: a.daysBonus || 0,
        overtime: a.overtime || 0,
        deduction: a.deduction || 0,
        bonusStatus: a.bonusStatus || 'NONE',
        bonusApprovedBy: a.bonusApprovedBy,
        bonusApprovedAt: a.bonusApprovedAt,
        bonusRejectionReason: a.bonusRejectionReason,
      };

      if (APPLY) {
        try {
          await PerformanceReview.create(newDoc);
          converted++;
        } catch (err) {
          errors++;
          console.error('ERR empId:', empId, 'period:', a.period, '->', err.message);
        }
      } else {
        converted++;
        console.log('  WOULD_CREATE empId:', empId.toString(),
          'period:', a.period?.year + '/' + a.period?.month,
          'bonus:', a.bonusStatus);
      }
    }
  }

  console.log('\n' + '─'.repeat(60));
  console.log('Converted:', converted);
  console.log('Skipped (already exist):', skipped);
  console.log('Errors:', errors);
  if (!APPLY) console.log('\n Run with --apply to execute');
  if (errors > 0) process.exit(1);
  await mongoose.disconnect();
}

run().catch(err => { console.error(err); process.exit(1); });
```

#### 1.2 — تشغيل وتحقق
